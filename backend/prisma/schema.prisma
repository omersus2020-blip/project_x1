// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  SUPPLIER
  ADMIN
}

enum TenderStatus {
  ACTIVE
  PENDING_APPROVAL
  COMPLETED
  CANCELLED
}

enum BidStatus {
  PENDING
  WON
  LOST
}

enum NotificationType {
  TENDER_WON
  TENDER_COMPLETED
  ORDER_CREATED
  DELIVERY_UPDATE
}

model User {
  id         String   @id @default(uuid())
  name       String
  email      String   @unique
  phone      String?
  password   String
  isVerified Boolean  @default(false)
  role       Role     @default(CUSTOMER)
  
  // Relations
  supplierProfile     Supplier?
  
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customerEnrollments CustomerEnrollment[]
  addresses           Address[]
  paymentMethods      PaymentMethod[]
  orders              Order[]
  notifications       Notification[]
  savedTenders        SavedTender[]
  otpCodes            OtpCode[]

  @@map("users")
}

model PendingUser {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  phone     String?
  password  String
  
  // Supplier specific data (optional during registration)
  companyNumber   String?
  bankAccount     String?
  businessAddress String?
  businessSector  String?
  contactName     String?
  contactPhone    String?

  createdAt DateTime @default(now())

  otpCodes OtpCode[]

  @@map("pending_users")
}

model Supplier {
  id                String   @id @default(uuid())
  userId            String   @unique
  name              String   // Company/Brand name
  email             String   // Business email
  companyNumber     String?
  bankAccount       String?
  businessAddress   String?
  businessSector    String?
  contactName       String?
  contactPhone      String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenders Tender[] @relation("SupplierTenders")
  bids    SupplierBid[]

  @@map("suppliers")
}

model Tender {
  id                  String       @id @default(uuid())
  title               String
  description         String
  originalPrice       Float
  currentPrice        Float
  targetParticipants  Int
  currentParticipants Int          @default(0)
  endDate             DateTime
  imageUrl            String
  status              TenderStatus @default(ACTIVE)
  category            String       @default("General")
  views               Int          @default(0)
  supplierId          String
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  supplier    Supplier             @relation("SupplierTenders", fields: [supplierId], references: [id], onDelete: Cascade)
  enrollments CustomerEnrollment[]
  bids        SupplierBid[]
  tiers       TenderTier[]
  orders      Order[]
  notifications Notification[]
  savedBy       SavedTender[]

  @@map("tenders")
}

model TenderTier {
  id              String   @id @default(uuid())
  tenderId        String
  minParticipants Int
  discountPercent Float
  createdAt       DateTime @default(now())

  tender Tender @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  @@map("tender_tiers")
}

model Order {
  id                String    @id @default(uuid())
  tenderId          String
  userId            String
  finalPrice        Float
  quantity          Int       @default(1)
  totalPrice        Float?    // finalPrice * quantity
  status            String    @default("PROCESSING") // PROCESSING, SHIPPED, DELIVERED
  deliveryAddress   String?
  estimatedDelivery DateTime?
  deliveryNotes     String?
  supplierBidId     String?
  userName          String?   // Human readable snapshot
  userEmail         String?   // Human readable snapshot
  tenderTitle       String?   // Human readable snapshot
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  tender     Tender      @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  supplierBid SupplierBid? @relation(fields: [supplierBidId], references: [id], onDelete: SetNull)

  @@map("orders")
}

model CustomerEnrollment {
  id              String   @id @default(uuid())
  tenderId        String
  userId          String
  quantity        Int      @default(1)  // Max 3 per tender
  addressId       String?  // Selected delivery address
  paymentMethodId String?  // Selected payment method
  userName        String?  // Human readable snapshot
  userEmail       String?  // Human readable snapshot
  tenderTitle     String?  // Human readable snapshot
  createdAt       DateTime @default(now())

  tender Tender @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenderId, userId])
  @@map("customer_enrollments")
}

model SupplierBid {
  id            String    @id @default(uuid())
  tenderId      String
  supplierId    String
  bidPrice      Float
  status        BidStatus @default(PENDING)
  supplierName  String?   // Human readable snapshot
  supplierEmail String?   // Human readable snapshot
  tenderTitle   String?   // Human readable snapshot
  createdAt     DateTime  @default(now())

  tender   Tender   @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  orders   Order[]

  @@map("supplier_bids")
}

model Notification {
  id          String           @id @default(uuid())
  userId      String
  title       String
  body        String
  type        NotificationType
  tenderId    String?
  tenderTitle String?          // Human readable snapshot
  isRead      Boolean          @default(false)
  createdAt   DateTime         @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  tender Tender? @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model Address {
  id        String   @id @default(uuid())
  userId    String
  label     String   @default("Home")
  street    String
  city      String
  state     String   @default("")
  zipCode   String?
  country   String   @default("Israel")
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("addresses")
}

model PaymentMethod {
  id          String   @id @default(uuid())
  userId      String
  label       String   @default("My Card")
  last4       String
  brand       String   @default("Visa")
  expiryMonth Int
  expiryYear  Int
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("payment_methods")
}

model SavedTender {
  id          String   @id @default(uuid())
  userId      String
  tenderId    String
  tenderTitle String?  // Human readable snapshot
  createdAt   DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tender Tender @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  @@unique([userId, tenderId])
  @@map("saved_tenders")
}

model OtpCode {
  id            String   @id @default(uuid())
  userId        String?
  pendingUserId String?
  code          String
  channel       String   @default("email")
  expiresAt     DateTime
  attempts      Int      @default(0)
  used          Boolean  @default(false)
  createdAt     DateTime @default(now())

  user        User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  pendingUser PendingUser? @relation(fields: [pendingUserId], references: [id], onDelete: Cascade)

  @@map("otp_codes")
}

